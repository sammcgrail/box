sebland.com {
    encode zstd gzip

    # === CACHE HEADERS ===

    # Immutable hashed assets (JS/CSS bundles with hash in filename) — cache 1 year
    @hashed_assets path_regexp \.(js|css|wasm)$
    header @hashed_assets Cache-Control "public, max-age=31536000, immutable"

    # HTML files — no cache (always revalidate)
    @html path_regexp \.html$
    header @html Cache-Control "no-cache"

    # === WEBSOCKET / SERVER APPS (reverse proxy) ===

    # mptodo — free-for-all todo list
    handle /mptodo* {
        reverse_proxy host.docker.internal:8767
    }

    # mppaint — Multiplayer Paint (WebSocket)
    handle /mppaint* {
        uri strip_prefix /mppaint
        reverse_proxy host.docker.internal:8770
    }

    # tank — Multiplayer Tank Battle (WebSocket)
    handle /tank* {
        uri strip_prefix /tank
        reverse_proxy host.docker.internal:8776
    }

    # === STATIC APPS (served directly by Caddy) ===

    # ascii — Conway's Game of Life
    @ascii_slash path /ascii/
    redir @ascii_slash /ascii temporary
    @ascii path /ascii /ascii/*
    handle @ascii {
        uri strip_prefix /ascii
        root * /srv/ascii
        try_files {path} /srv/ascii/index.html
        file_server {
            precompressed gzip
        }
    }

    # paint — MSPaint clone
    @paint_slash path /paint/
