# Serve on port 80 (HTTP only — works with bare IP)
# To enable HTTPS with a domain, replace ":80" with "yourdomain.com"
# and Caddy will automatically provision a Let's Encrypt certificate.
:80 {
    encode gzip

    # seb status dashboard (basic auth protected)
    handle /seb* {
        basicauth {
            seb $2a$14$0.SeIVFOQocN6SKk.jVtGeTqh2C1ksc/VEStWdSWCi8IpA71PHMvy
        }
        reverse_proxy host.docker.internal:8765
    }

    # scratch metrics dashboard (basic auth protected)
    handle /scratch* {
        basicauth {
            seb $2a$14$0.SeIVFOQocN6SKk.jVtGeTqh2C1ksc/VEStWdSWCi8IpA71PHMvy
        }
        reverse_proxy host.docker.internal:8766
    }

    # SPA — all other paths
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
