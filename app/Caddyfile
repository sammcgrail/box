    # === ADMIN DASHBOARDS ===

    # netdata monitoring dashboard (basic auth protected)
    handle /monitoring* {
        uri strip_prefix /monitoring
        basicauth {
            seb $2a$14$0.SeIVFOQocN6SKk.jVtGeTqh2C1ksc/VEStWdSWCi8IpA71PHMvy
        }
        reverse_proxy host.docker.internal:19999
    }

    # airhorn — AIRHORN button
