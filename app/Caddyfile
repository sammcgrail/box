    # sparks — 3D atomic viewer
    @sparks_noslash path /sparks
    rewrite @sparks_noslash /sparks/
    handle /sparks/* {
        uri strip_prefix /sparks
        root * /srv/sparks
        try_files {path} /srv/sparks/index.html
