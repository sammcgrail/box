sebland.com {
    encode gzip

    # mptodo — free-for-all todo list
    handle /mptodo* {
        reverse_proxy host.docker.internal:8767
    }

    # ascii — Conway's Game of Life
    handle /ascii* {
        uri strip_prefix /ascii
        reverse_proxy host.docker.internal:8768
    }

    # paint — MSPaint clone
    handle /paint* {
        uri strip_prefix /paint
        reverse_proxy host.docker.internal:8769
    }

    # mppaint — Multiplayer Paint (WebSocket)
    handle /mppaint* {
        uri strip_prefix /mppaint
        reverse_proxy host.docker.internal:8770
    }

    # tetris — Classic Tetris
    handle /tetris* {
        uri strip_prefix /tetris
        reverse_proxy host.docker.internal:8771
    }

    # brick — Brick Breaker
    @brick_noslash path /brick
    redir @brick_noslash /brick/ permanent
    handle /brick/* {
        uri strip_prefix /brick
        reverse_proxy host.docker.internal:8772
    }

    # minesweeper — Win95 Minesweeper
    handle /minesweeper* {
        uri strip_prefix /minesweeper
        reverse_proxy host.docker.internal:8773
    }

    # snake — Nokia Snake
    handle /snake* {
        uri strip_prefix /snake
        reverse_proxy host.docker.internal:8774
    }

    # tank — Multiplayer Tank Battle (WebSocket)
    handle /tank* {
        uri strip_prefix /tank
        reverse_proxy host.docker.internal:8776
    }

    # sand — Sand Game (Falling Sand Simulation)
    @sand_noslash path /sand
    redir @sand_noslash /sand/ permanent
    handle /sand/* {
        uri strip_prefix /sand
        reverse_proxy host.docker.internal:8777
    }

    # tower — PixelClash Tower Defense
    @tower_noslash path /tower
    redir @tower_noslash /tower/ permanent
    handle /tower/* {
        uri strip_prefix /tower
        reverse_proxy host.docker.internal:8778
    }

    # chess — 6D Chess
    @chess_noslash path /chess
    redir @chess_noslash /chess/ permanent
    handle /chess/* {
        uri strip_prefix /chess
        reverse_proxy host.docker.internal:8779
    }

    # limericks — St. Patrick's Day limericks
    @limericks_noslash path /limericks
    redir @limericks_noslash /limericks/ permanent
    handle /limericks/* {
        uri strip_prefix /limericks
        reverse_proxy host.docker.internal:8775
    }

    # netdata monitoring dashboard (basic auth protected)
    handle /monitoring* {
        uri strip_prefix /monitoring
        basicauth {
            seb $2a$14$0.SeIVFOQocN6SKk.jVtGeTqh2C1ksc/VEStWdSWCi8IpA71PHMvy
        }
        reverse_proxy host.docker.internal:19999
    }

    # seb status dashboard (basic auth protected)
    handle /seb* {
        uri strip_prefix /seb
        basicauth {
            seb $2a$14$0.SeIVFOQocN6SKk.jVtGeTqh2C1ksc/VEStWdSWCi8IpA71PHMvy
        }
        reverse_proxy host.docker.internal:8765
    }

    # SPA — all other paths
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
