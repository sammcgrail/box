sebland.com {
    encode gzip

    # mptodo — free-for-all todo list
    handle /mptodo* {
        reverse_proxy host.docker.internal:8767
    }

    # seb status dashboard (basic auth protected)
    handle /seb* {
        uri strip_prefix /seb
        basicauth {
            seb $2a$14$0.SeIVFOQocN6SKk.jVtGeTqh2C1ksc/VEStWdSWCi8IpA71PHMvy
        }
        reverse_proxy host.docker.internal:8765
    }

    # SPA — all other paths
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
