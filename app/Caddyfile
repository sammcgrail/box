        uri strip_prefix /brick
        root * /srv/brick
        try_files {path} /srv/brick/index.html
        file_server {
            precompressed gzip
        }
    }

    # minesweeper — Win95 Minesweeper
    @minesweeper_noslash path /minesweeper
    rewrite @minesweeper_noslash /minesweeper/
    handle /minesweeper/* {
        uri strip_prefix /minesweeper
        root * /srv/minesweeper
        try_files {path} /srv/minesweeper/index.html
        file_server {
            precompressed gzip
        }
    }

    # snake — Nokia Snake
    @snake_noslash path /snake
    rewrite @snake_noslash /snake/
    handle /snake/* {
        uri strip_prefix /snake
        root * /srv/snake
        try_files {path} /srv/snake/index.html
        file_server {
            precompressed gzip
        }
    }

    # sand — Sand Game (Falling Sand Simulation)
    @sand_noslash path /sand
    rewrite @sand_noslash /sand/
    handle /sand/* {
        uri strip_prefix /sand
        root * /srv/sand
        try_files {path} /srv/sand/index.html
        file_server {
            precompressed gzip
        }
    }

    # tower — PixelClash Tower Defense
    @tower_noslash path /tower
    rewrite @tower_noslash /tower/
    handle /tower/* {
        uri strip_prefix /tower
        root * /srv/tower
        try_files {path} /srv/tower/index.html
        file_server {
            precompressed gzip
        }
    }

    # chess — 6D Chess
    @chess_noslash path /chess
    rewrite @chess_noslash /chess/
    handle /chess/* {
        uri strip_prefix /chess
        root * /srv/chess
        try_files {path} /srv/chess/index.html
        file_server {
            precompressed gzip
        }
    }

    # cat — Random cats from cataas
    @cat_noslash path /cat
    rewrite @cat_noslash /cat/
    handle /cat/* {
        uri strip_prefix /cat
        root * /srv/cat
        try_files {path} /srv/cat/index.html
        file_server {
            precompressed gzip
        }
    }

    # radarling — Weather radar globe viewer
    @radarling_noslash path /radarling
    rewrite @radarling_noslash /radarling/
    handle /radarling/* {
        uri strip_prefix /radarling
        reverse_proxy host.docker.internal:20000
    }

    # pickleball — Pickleball score tracker
    @pickleball_noslash path /pickleball
    rewrite @pickleball_noslash /pickleball/
    handle /pickleball/* {
        uri strip_prefix /pickleball
        root * /srv/pickleball
        try_files {path} /srv/pickleball/index.html
